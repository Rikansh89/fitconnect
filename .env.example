# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fitconnect?retryWrites=true&w=majority

# JWT Secret key (change this to a random string)
JWT_SECRET=your_jwt_secret_key_here

# Server port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
